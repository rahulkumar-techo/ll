    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "dev": "expo start --clear",
    "doctor": "pnpm dlx expo-doctor",
    "fix": "pnpm dlx expo install --fix",
    "clean": "rm -rf node_modules pnpm-lock.yaml && pnpm install",
    "reset": "rm -rf node_modules pnpm-lock.yaml .expo && pnpm install",
    "env": "npx expo-env-info",
    "full-fix": "pnpm run clean && pnpm run fix && pnpm run dev"
  },
