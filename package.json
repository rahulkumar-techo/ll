{
  "name": "ll",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "dev": "expo start --clear",
    "doctor": "pnpm dlx expo-doctor",
    "fix": "pnpm dlx expo install --fix",
    "clean": "node -e \"const fs=require('node:fs'); for (const path of ['node_modules','pnpm-lock.yaml']) fs.rmSync(path,{ recursive:true, force:true });\" && pnpm install",
    "reset": "node -e \"const fs=require('node:fs'); for (const path of ['node_modules','pnpm-lock.yaml','.expo']) fs.rmSync(path,{ recursive:true, force:true });\" && pnpm install",
    "env": "npx expo-env-info",
    "full-fix": "pnpm run clean && pnpm run fix && pnpm run dev"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-native-vector-icons/material-design-icons": "^13.0.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@supabase/supabase-js": "^2.103.0",
    "expo": "~55.0.15",
    "expo-auth-session": "^55.0.14",
    "expo-crypto": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-image": "~55.0.8",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.11",
    "expo-router": "~55.0.12",
    "expo-splash-screen": "~55.0.18",
    "expo-symbols": "~55.0.7",
    "expo-web-browser": "~55.0.14",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~55.0.16",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true
}
